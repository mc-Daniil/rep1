service ctf_string
{
    disable     = no
    socket_type = stream
    protocol    = tcp
    wait        = no
    user        = ctf
    type        = UNLISTED
    port        = 1337
    bind        = 0.0.0.0
    server      = /challenge/string
    banner_fail = /etc/banner_fail
    per_source  = 10
    instances   = 30
    log_type    = SYSLOG daemon
    log_on_success = PID HOST DURATION
    log_on_failure = HOST
}